{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "void": {
        "950": { "$value": "#080706", "$type": "color" },
        "900": { "$value": "#0B0A08", "$type": "color" },
        "800": { "$value": "#131110", "$type": "color" },
        "700": { "$value": "#1B1815", "$type": "color" }
      },
      "line": {
        "500": { "$value": "#2C2820", "$type": "color" },
        "700": { "$value": "#211E18", "$type": "color" }
      },
      "ivory": {
        "100": { "$value": "#F3EEE2", "$type": "color" },
        "300": { "$value": "#EAE3D3", "$type": "color" },
        "500": { "$value": "#8F8676", "$type": "color" }
      },
      "bronze": {
        "300": { "$value": "#E0BD7E", "$type": "color" },
        "500": { "$value": "#C6A15B", "$type": "color" },
        "700": { "$value": "#8A6B36", "$type": "color" },
        "900": { "$value": "#3E3018", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-cormorant), 'Cormorant Garamond', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-inter), Inter, system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-plex-mono), 'IBM Plex Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "220ms", "$type": "duration" },
        "base": { "$value": "500ms", "$type": "duration" },
        "reveal": { "$value": "1.3s", "$type": "duration" },
        "processional": { "$value": "2.2s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "hush": { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "0.01em", "$type": "dimension" },
      "label": { "$value": "0.32em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.void.900}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ivory.300}", "$type": "color" },
    "card": { "$value": "{primitive.color.void.800}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ivory.300}", "$type": "color" },
    "muted": { "$value": "{primitive.color.void.800}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ivory.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.bronze.500}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.void.900}", "$type": "color" },
    "border": { "$value": "{primitive.color.line.500}", "$type": "color" },
    "ring": { "$value": "{primitive.color.bronze.500}", "$type": "color" },
    "radius": { "$value": "0rem", "$type": "dimension" },
    "bronze": { "$value": "{primitive.color.bronze.500}", "$type": "color" },
    "bronze-bright": { "$value": "{primitive.color.bronze.300}", "$type": "color" },
    "bronze-dim": { "$value": "{primitive.color.bronze.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.line.500}", "$type": "color" },
    "void-deep": { "$value": "{primitive.color.void.950}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-hush": { "$value": "{primitive.motion.ease.hush}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.4rem, 6vw, 4.6rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.08", "$type": "number" },
      "vignette": {
        "$value": "radial-gradient(ellipse 80% 60% at 50% 40%, rgba(198, 161, 91, 0.07), transparent 65%)",
        "$type": "gradient"
      }
    },
    "label": {
      "accession-color": { "$value": "{primitive.color.bronze.500}", "$type": "color" },
      "spacing": { "$value": "clamp(2.5rem, 6vw, 5rem)", "$type": "dimension" }
    },
    "button": {
      "ghost-border": { "$value": "{primitive.color.bronze.700}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.bronze.500}", "$type": "color" },
      "ghost-fg": { "$value": "{primitive.color.bronze.300}", "$type": "color" }
    }
  }
}
